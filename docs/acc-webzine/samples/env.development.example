# acc-webzine 프로젝트 루트에 .env.development 로 복사 (Vite)
# 백엔드 server.port 와 반드시 같게 맞춘다.
#
# Gradle bootRun (기본): 8080
VITE_API_BASE_URL=http://localhost:8080
#
# Docker compose app 프로필: 9090
# VITE_API_BASE_URL=http://localhost:9090
#
# Kakao 지도 JavaScript 키
# VITE_KAKAO_MAP_APP_KEY=your_kakao_javascript_key
