# Jenkins 로컬 Docker 설정
# 사용법: cp .env.example .env 후 값 수정

# Jenkins 베이스 이미지
# - 최신(주간) 빌드: jenkins/jenkins:jdk21  (기본)
# - 안정 LTS:       jenkins/jenkins:lts-jdk21
JENKINS_BASE_IMAGE=jenkins/jenkins:jdk21

JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=IdolGlow!7077
IDOLGLOW_WORKSPACE=D:/intel3/IdolGlow
JENKINS_DEPLOY_HOST_PATH=D:/intel3/IdolGlow/infra/jenkins-local/deployments

# Git → Jenkins (저장소 push 시 Jenkinsfile·infra/ 등 전체 반영)
# Public repo: GITHUB_REPO_URL 만 설정해도 됩니다.
# Private repo: GITHUB_TOKEN + GITHUB_USERNAME 도 설정하세요.
GITHUB_REPO_URL=https://github.com/skyleedevzero86/IdolGlow.git
GITHUB_BRANCH=*/chor/dev
JENKINS_JOB_NAME=IdolGlow
JENKINS_SCM_POLL=H/2 * * * *

GITHUB_CREDENTIALS_ID=github-http-token
GITHUB_USERNAME=
GITHUB_TOKEN=

# ── Git push → Jenkins 적용 흐름 ──
# 1) 위 GITHUB_REPO_URL 설정 후 .\start-jenkins.ps1 로 기동
# 2) init 스크립트가 IdolGlow Pipeline Job 을 자동 생성 (Poll SCM 2분)
# 3) git push 후 최대 2분 내 자동 빌드, 또는 Jenkins UI 에서 Build Now
# 4) 빌드 시 checkout scm 으로 원격 저장소 전체를 가져옴 (Jenkinsfile, infra/, backend/ …)
# ※ 즉시 반영: Jenkins Job → Build Triggers → GitHub hook trigger 활성화 (Webhook)
