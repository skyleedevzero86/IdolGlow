# infra/docker-compose.yml 환경 변수 예시
# 사용법: cp .env.example .env 후 값 수정

# 백엔드 프로필 (기본: prod + select)
SPRING_PROFILES_ACTIVE=prod,select

# Jasypt 복호화 키 (application-select.yml 과 동일하게 맞추세요)
JASYPT_ENCRYPTOR_PASSWORD=idolglow-dev-secret-2026!

# 프론트엔드 소스 경로 (기본: docs/acc-webzine, frontend 로 옮기면 frontend)
FRONTEND_DIR=docs/acc-webzine

# 프론트엔드 Docker 빌드 타겟 (docs/acc-webzine: static, frontend: next)
FRONTEND_TARGET=static

# 결제 mock 웹훅 시크릿
MOCK_PAYMENT_WEBHOOK_SECRET=dev-mock-webhook-secret
